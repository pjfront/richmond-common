# Richmond Transparency Project — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# --- Required for Phase 1 ---

# Anthropic API key (for Claude extraction)
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional for Phase 1, required later ---

# Socrata API (Transparent Richmond open data portal)
# Get a free app token at https://www.transparentrichmond.org/
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=www.transparentrichmond.org

# PostgreSQL connection (local dev or hosted)
DATABASE_URL=postgresql://localhost:5432/richmond_transparency

# Email (for submitting public comments to City Clerk)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
COMMENT_FROM_EMAIL=
