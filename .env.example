# Richmond Transparency Project — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# --- Required for Phase 1 ---

# Anthropic API key (for Claude extraction)
ANTHROPIC_API_KEY=sk-ant-...

# --- Required for Phase 2 (Supabase + Frontend) ---

# Supabase project URL (Settings → General → Reference ID, or API Keys page)
# Format: https://xxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable/anon key (API Keys page → "Publishable key" starting with sb_publishable_...)
SUPABASE_ANON_KEY=sb_publishable_...

# PostgreSQL connection string (Database → Connection string → URI tab)
# This is used by the Python pipeline (db.py) to load data into Supabase
# Replace [YOUR-PASSWORD] with the password you set when creating the project
DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# --- Optional for Phase 1, required later ---

# Socrata API (Transparent Richmond open data portal)
# Get a free app token at https://www.transparentrichmond.org/
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=www.transparentrichmond.org

# Email (for submitting public comments to City Clerk)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
COMMENT_FROM_EMAIL=
